PORT=3001
NODE_ENV=development
DATABASE_PATH=../../data/auth.db
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
LOG_LEVEL=info

# Database URL for MongoDB
DATABASE_URL="mongodb://localhost:27017/epfms?authSource=admin"
# Atlas:
# DATABASE_URL="mongodb+srv://<username>:<password>@<cluster-address>/epfms?retryWrites=true&w=majority"
