# Prefer GATEWAY_PORT — generic PORT is often 3001 in other services' .env files and breaks the gateway if copied by mistake.
GATEWAY_PORT=8080
NODE_ENV=development
JWT_SECRET=change-me-in-production-use-long-random-string
INTERNAL_SERVICE_KEY=shared-internal-key-between-services
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
NOTIFICATION_SERVICE_URL=http://localhost:3003
PERFORMANCE_SERVICE_URL=http://localhost:8001
FEEDBACK_SERVICE_URL=http://localhost:8002
ANALYTICS_SERVICE_URL=http://localhost:8004
AI_INSIGHTS_SERVICE_URL=http://localhost:8005
AI_SERVICE_KEY=epfms-local-ai-key-change-me
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
LOG_LEVEL=info
